# =============================================================================
# AI Tutor Academy — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- Database (Supabase PostgreSQL) ---
# Transaction/pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma Migrate)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- OpenAI (AI Tutor Engine) ---
OPENAI_API_KEY="sk-..."

# --- Logging (optional) ---
# LOG_LEVEL=debug   # debug | info | warn | error (defaults to "info" in production)
# AI_MODEL_PRIMARY=gpt-4o
# AI_MODEL_FAST=gpt-4o-mini
# AI_EMBEDDING_MODEL=text-embedding-3-small
