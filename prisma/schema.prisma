generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PARENT
  ADMIN
}

enum LessonStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum SessionPhase {
  GREETING
  TOPIC_SELECTION
  TEACHING
  CHECK
  PRACTICE
  RETEACH
  QUIZ
  GAME
  RESULTS
  WRAP_UP
}

// User (Parent or Admin)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(PARENT)

  children Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Student (Child Profile)
model Student {
  id        String   @id @default(cuid())
  name      String
  grade     String?
  xp        Int      @default(0)
  avatar    String?
  interests String[] @default([])

  parentId String
  parent   User   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  progress       LessonProgress[]
  achievements   Achievement[]
  gameScores     GameScore[]
  tutorSessions  TutorSession[]
  topicMastery   TopicMastery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AI Tutor Session - one per lesson sitting
model TutorSession {
  id        String       @id @default(cuid())
  studentId String
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  lessonId  String?
  lesson    Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  phase     SessionPhase @default(GREETING)
  topic     String?
  bloomLevel Int         @default(1)

  messages  TutorMessage[]

  score       Int?
  xpAwarded   Int       @default(0)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
}

// Individual messages in a tutor session
model TutorMessage {
  id        String       @id @default(cuid())
  sessionId String
  session   TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role      String       // user, assistant, system, tool
  content   String
  metadata  Json?        // tool calls, quiz data, game params, etc.

  createdAt DateTime     @default(now())
}

// Per-topic mastery tracking
model TopicMastery {
  id         String  @id @default(cuid())
  studentId  String
  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  topic      String
  subject    String
  bloomLevel Int     @default(1)
  confidence Float   @default(0)
  attempts   Int     @default(0)
  correct    Int     @default(0)

  lastPracticed DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, topic])
}

// RAG content embeddings
model ContentEmbedding {
  id        String                   @id @default(cuid())
  content   String
  embedding Unsupported("vector(1536)")?
  source    String
  topic     String
  subject   String
  keyStage  String
  bloomLevel Int                     @default(1)

  createdAt DateTime                 @default(now())

  @@index([subject, keyStage])
}

// Curriculum - Subject
model Subject {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String?
  icon        String?
  keyStage    String
  order       Int      @default(0)

  modules   Module[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Curriculum - Module (topic/unit within a subject)
model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  lessons Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Curriculum - Lesson (individual lesson within a module)
model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  duration    Int?
  order       Int      @default(0)

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  progress      LessonProgress[]
  tutorSessions TutorSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Progress Tracking
model LessonProgress {
  id        String       @id @default(cuid())
  lessonId  String
  status    LessonStatus @default(LOCKED)
  score     Int          @default(0)
  
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  @@unique([studentId, lessonId])
}

// Gamification - Achievements Unlocked
model Achievement {
  id            String   @id @default(cuid())
  achievementId String   // ID of the achievement (e.g., "first-lesson")
  unlockedAt    DateTime @default(now())
  
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, achievementId])
}

// Gamification - Game Scores
model GameScore {
  id        String   @id @default(cuid())
  gameId    String
  score     Int
  xpEarned  Int      @default(0)

  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  playedAt  DateTime @default(now())
}
